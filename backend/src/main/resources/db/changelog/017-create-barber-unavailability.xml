<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-barber-unavailability" author="sergio">

        <createTable tableName="barber_unavailability">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints
                        primaryKey="true"
                        primaryKeyName="pk_barber_unavailability"/>
            </column>

            <column name="barbershop_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="barber_id" type="BIGINT"/>

            <column name="start_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>

            <column name="end_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>

            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="recurrence" type="VARCHAR(50)"/>

            <column name="recurrence_until"
                    type="TIMESTAMP WITH TIME ZONE"/>

            <column name="reason" type="VARCHAR(255)"/>

            <column name="created_at"
                    type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="barber_unavailability"
                baseColumnNames="barbershop_id"
                referencedTableName="barbershops"
                referencedColumnNames="id"
                constraintName="fk_unavailability_barbershop"/>

        <addForeignKeyConstraint
                baseTableName="barber_unavailability"
                baseColumnNames="barber_id"
                referencedTableName="barbers"
                referencedColumnNames="id"
                constraintName="fk_unavailability_barber"/>

        <createIndex
                tableName="barber_unavailability"
                indexName="idx_unavailability_barbershop_id">
            <column name="barbershop_id"/>
        </createIndex>

        <createIndex
                tableName="barber_unavailability"
                indexName="idx_unavailability_barber_id">
            <column name="barber_id"/>
        </createIndex>

        <createIndex
                tableName="barber_unavailability"
                indexName="idx_unavailability_start_time">
            <column name="start_time"/>
        </createIndex>

        <createIndex
                tableName="barber_unavailability"
                indexName="idx_unavailability_end_time">
            <column name="end_time"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>