<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="add-barber-id-to-admin-users" author="sergio">

        <addColumn tableName="admin_users">
            <column name="barber_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
                baseTableName="admin_users"
                baseColumnNames="barber_id"
                referencedTableName="barbers"
                referencedColumnNames="id"
                constraintName="fk_admin_users_barber"/>

        <createIndex
                tableName="admin_users"
                indexName="idx_admin_users_barber_id">
            <column name="barber_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>