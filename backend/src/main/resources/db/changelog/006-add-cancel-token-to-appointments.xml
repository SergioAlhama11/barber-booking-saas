<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-add-cancel-token-to-appointments" author="sergio">

        <!-- 🔐 Token de cancelación -->
        <addColumn tableName="appointments">
            <column name="cancel_token" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>

            <column name="cancel_token_expires_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- 🔒 Unicidad del token -->
        <addUniqueConstraint
                tableName="appointments"
                columnNames="cancel_token"
                constraintName="uk_appointments_cancel_token"/>

        <!-- ⚡ Índice para búsquedas rápidas -->
        <createIndex tableName="appointments" indexName="idx_cancel_token">
            <column name="cancel_token"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>