<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-add-cancelled-at-to-appointments" author="sergio">

        <addColumn tableName="appointments">
            <column name="cancelled_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>

        <!-- ⚡ índice opcional para queries futuras -->
        <createIndex tableName="appointments" indexName="idx_appointments_cancelled_at">
            <column name="cancelled_at"/>
        </createIndex>


    </changeSet>

</databaseChangeLog>